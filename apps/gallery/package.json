{
  "name": "gallery",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "corepack pnpm -w run registry:build",
    "dev": "vite",
    "prebuild": "corepack pnpm -w run registry:build",
