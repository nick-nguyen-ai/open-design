{
  "name": "enterprise-design",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc -b && corepack pnpm -r --if-present run typecheck",
    "pretest": "corepack pnpm run registry:build",
    "test": "vitest run --passWithNoTests && corepack pnpm -r --if-present run test",
    "build": "corepack pnpm -r --if-present run build",
    "registry:build": "corepack pnpm exec tsx packages/registry/src/cli.ts build",
    "registry:validate": "corepack pnpm exec tsx packages/registry/src/cli.ts validate"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^24.13.3",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.5",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
